<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Signup</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

  <%- include('../partials/head') %>

  <div class="flex justify-center items-center min-h-screen">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
      
      <h2 class="text-2xl font-bold mb-6 text-center text-red-500">
        Create Account
      </h2>

      <form action="/signup" method="POST" class="space-y-4">

       <%- include('../partials/error') %>
        <!-- First Name -->
        <div>
          <label class="block mb-1 font-medium">First Name</label>
          <input
            type="text"
            name="firstName"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.firstName : '' %>"
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          />
        </div>

        <!-- Last Name -->
        <div>
          <label class="block mb-1 font-medium">Last Name</label>
          <input
            type="text"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.lastName : '' %>"

            name="lastName"
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          />
        </div>

        <!-- Email -->
        <div>
          <label class="block mb-1 font-medium">Email</label>
          <input
            type="email"
            name="email"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>"
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          />
        </div>

        <!-- Password -->
        <div>
          <label class="block mb-1 font-medium">Password</label>
          <input
            type="password"
            name="password"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.password : '' %>"
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          />
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block mb-1 font-medium">Confirm Password</label>
          <input
            type="password"
            name="confirmPassword"
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          />
        </div>

        <!-- Role Dropdown -->
        <div>
          <label class="block mb-1 font-medium">Register As</label>
          <select
            name="userType"         
            required
            class="w-full border rounded px-3 py-2 focus:ring-2 focus:ring-red-400 outline-none"
          >
            <option value="">Select Role</option>
            <option value="user" >User</option>
            <option value="host" >Host</option>
          </select>
        </div>

        <!-- Terms & Conditions -->
        <div class="flex items-center">
          <input
            type="checkbox"
            name="terms"
            required
            class="mr-2"
          />
          <label class="text-sm">
            I agree to the 
            <a href="#" class="text-red-500 hover:underline">
              Terms & Conditions
            </a>
          </label>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-red-500 text-white py-2 rounded hover:bg-red-600 transition"
        >
          Signup
        </button>

      </form>

      <!-- Login redirect -->
      <p class="mt-4 text-center text-sm">
        Already have an account?
        <a href="/login" class="text-red-500 hover:underline">Login</a>
      </p>

    </div>
  </div>

</body>
</html>