<%- include('../partials/head') %>
</head>

<body class="bg-[#F8FAFC] font-sans">

  <%- include('../partials/nav') %>

  <div class="flex justify-center items-center min-h-screen">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
      
      <h2 class="text-2xl font-bold mb-6 text-center text-[#0F172A]">
        Create Account
      </h2>

      <form action="/signup" method="POST" class="space-y-4">

        <%- include('../partials/error') %>

        <!-- First Name -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">First Name</label>
          <input
            type="text"
            name="firstName"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.firstName : '' %>"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          />
        </div>

        <!-- Last Name -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">Last Name</label>
          <input
            type="text"
            name="lastName"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.lastName : '' %>"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          />
        </div>

        <!-- Email -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">Email</label>
          <input
            type="email"
            name="email"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          />
        </div>

        <!-- Password -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">Password</label>
          <input
            type="password"
            name="password"
            value="<%= typeof oldInput !== 'undefined' ? oldInput.password : '' %>"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          />
        </div>

        <!-- Confirm Password -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">Confirm Password</label>
          <input
            type="password"
            name="confirmPassword"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          />
        </div>

        <!-- Role Dropdown -->
        <div>
          <label class="block mb-1 font-medium text-gray-700">Register As</label>
          <select
            name="userType"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-2 focus:ring-[#0F172A] outline-none"
          >
            <option value="">Select Role</option>
            <option value="user">User</option>
            <option value="host">Host</option>
          </select>
        </div>

        <!-- Terms & Conditions -->
        <div class="flex items-center">
          <input
            type="checkbox"
            name="terms"
            required
            class="mr-2"
          />
          <label class="text-sm text-gray-700">
            I agree to the 
            <a href="#" class="text-[#0F172A] hover:underline">
              Terms & Conditions
            </a>
          </label>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="w-full bg-[#0F172A] text-white py-2 rounded hover:bg-[#1E293B] transition duration-300"
        >
          Signup
        </button>

      </form>

      <!-- Login redirect -->
      <p class="mt-4 text-center text-sm text-gray-700">
        Already have an account?
        <a href="/login" class="text-[#0F172A] hover:underline">Login</a>
      </p>

    </div>
  </div>

</body>
</html>