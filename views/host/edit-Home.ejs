<%- include('../partials/head') %>
</head>

<body class="bg-[#F8FAFC] font-sans">

  <%- include('../partials/nav') %>

  <!-- Main Content -->
  <main class="container mx-auto px-6 py-12">
    <div class="max-w-lg mx-auto bg-white p-8 rounded-lg shadow-lg">
      
      <h2 class="text-2xl font-bold text-[#0F172A] mb-6 text-center">
        <%= editing ? "Edit" : "Register" %> your home
      </h2>

      <form action="/host/<%= editing ? 'edit-home' : 'add-home' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
        
        <!-- Hidden ID -->
        <input type="hidden" value="<%= editing ? home._id : '' %>" name="id" />

        <!-- House Name -->
        <div>
          <label for="houseName" class="block text-lg font-medium text-gray-700">House Name</label>
          <input
            type="text"
            name="houseName"
            id="houseName"
            value="<%= editing ? home.houseName : '' %>"
            placeholder="Enter the name of your house"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
            required
          />
        </div>

        <!-- Price Per Night -->
        <div>
          <label for="price" class="block text-lg font-medium text-gray-700">Price per Night</label>
          <input
            type="number"
            name="price"
            id="price"
            value="<%= editing ? home.price : '' %>"
            placeholder="Enter price per night"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
            required
          />
        </div>

        <!-- Location -->
        <div>
          <label for="location" class="block text-lg font-medium text-gray-700">Location</label>
          <input
            type="text"
            name="location"
            id="location"
            value="<%= editing ? home.location : '' %>"
            placeholder="Enter house location"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
            required
          />
        </div>

        <!-- Rating -->
        <div>
          <label for="rating" class="block text-lg font-medium text-gray-700">Rating</label>
          <input
            type="number"
            name="rating"
            id="rating"
            value="<%= editing ? home.rating : '' %>"
            placeholder="Rating (e.g. 4.5)"
            step="0.1"
            min="0"
            max="5"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
            required
          />
        </div>

        <!-- Photo Upload -->
        <div>
          <label for="photo" class="block text-lg font-medium text-gray-700">Photos</label>
          <input
            type="file"
            name="photo"
            accept="image/jpg, image/jpeg, image/png"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
          />
        </div>

        <!-- Description -->
        <div>
          <label for="description" class="block text-lg font-medium text-gray-700">House description</label>
          <textarea
            name="description"
            id="description"
            placeholder="Enter the description of your house"
            class="mt-2 w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#0F172A] focus:border-transparent"
            required
          ><%= editing ? home.description : '' %></textarea>
        </div>

        <!-- Submit Button -->
        <div>
          <button
            type="submit"
            class="w-full bg-[#0F172A] text-white py-2 rounded-md hover:bg-[#1E293B] transition duration-300"
          >
            <%= editing ? "Update Home" : "Add Home" %>
          </button>
        </div>
        
      </form>
    </div>
  </main>

</body>
</html>