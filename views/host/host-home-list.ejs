<%- include('../partials/head') %>
</head>
<body class="bg-[#F8FAFC] font-sans text-gray-800">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">
    <h2 class="text-4xl font-bold text-center text-[#0F172A] mb-6">
        Welcome to <span class="text-[#0F172A] font-semibold">NomadNest</span>
    </h2>
    
    <!-- Image section (optional for decoration) -->
    <div class="flex justify-center mb-12">
        <img src="https://via.placeholder.com/800x400" alt="NomadNest" class="rounded-lg shadow-lg">
    </div>

    <!-- Description -->
    <p class="text-lg text-center text-gray-600 mb-12">
        HOST  Discover beautiful homes and experiences hosted by wonderful people all over the world.
        Here are your registered homes:
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% registeredHomes.forEach(home => { %>
            <li class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition duration-300">
                <div class="cursor-pointer">
                    <!-- House Image -->
                    <img
                        src="<%= home.photo %>"
                        alt="<%= home.houseName %>"
                        class="w-full h-48 object-cover"
                        onclick="window.location.href='/home-details/<%= home._id %>'"
                    />

                    <!-- Card Content -->
                    <div class="p-4 space-y-2">
                        <!-- House Name -->
                        <h2 class="text-xl font-semibold text-[#0F172A]">
                            <%= home.houseName %>
                        </h2>

                        <!-- Location -->
                        <p class="text-gray-600">
                            📍 <%= home.location %>
                        </p>

                        <!-- Price & Rating -->
                        <div class="flex justify-between items-center pt-2">
                            <span class="text-lg font-bold text-[#0F172A]">
                                ₹ <%= home.price %> / night
                            </span>

                            <span class="flex items-center text-yellow-500 font-medium">
                                ⭐ <%= home.rating %>
                            </span>
                        </div>

                        <!-- Edit & Delete Buttons -->
                        <div class="pt-4 flex gap-3">
                            <!-- Edit Button -->
                            <a href="/host/edit-home/<%= home._id %>?editing=true"
                               class="w-1/2 text-center bg-[#0F172A] hover:bg-[#1E293B] text-white font-semibold py-2 px-4 rounded-lg transition duration-300">
                                Edit
                            </a>

                            <!-- Delete Button -->
                            <form action="/host/delete-home/<%= home._id %>" method="POST" class="w-1/2">
                                <button type="submit"
                                    class="w-full bg-[#DC2626] hover:bg-[#B91C1C] text-white font-semibold py-2 px-4 rounded-lg transition duration-300"
                                    onclick="return confirm('Are you sure you want to delete this home?');">
                                    Delete
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </li>
        <% }); %>
    </ul>

</main>

<!-- Footer -->
<footer class="bg-white py-8 mt-12 shadow-inner">
    <div class="container mx-auto text-center text-gray-600">
        <p>&copy; 2025 NomadNest, Inc. All rights reserved.</p>
    </div>
</footer>

</body>
</html>