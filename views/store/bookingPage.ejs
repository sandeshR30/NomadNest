<%- include('../partials/head') %>
</head>
<body class="bg-[#F8FAFC] font-sans text-gray-800">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-16">

    <div class="text-center mb-10">
        <h1 class="text-4xl font-bold text-[#0F172A] mb-4">
            Booking Page
        </h1>

        <p class="text-gray-600 text-lg">
            Select your check-in and check-out dates below.
        </p>
    </div>

    <!-- Booking Form -->
    <div class="flex justify-center">
        <form action="/book/<%- HomeId %>" method="POST"
              class="bg-white shadow-md rounded-xl p-8 border border-gray-100 w-full max-w-md space-y-6">

            <!-- Check-in -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Check-in Date
                </label>
                <input 
                    type="date" 
                    name="checkIn"
                    required
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#0F172A]"
                />
            </div>

            <!-- Check-out -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    Check-out Date
                </label>
                <input 
                    type="date" 
                    name="checkOut"
                    required
                    class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#0F172A]"
                />
            </div>

            <!-- Submit -->
            <button 
                type="submit"
                class="w-full bg-[#0F172A] hover:bg-[#1E293B] text-white font-semibold py-2.5 px-4 rounded-lg transition duration-300">
                Confirm Booking
            </button>

        </form>
    </div>

</main>

</body>
</html>