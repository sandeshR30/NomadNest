<%- include('../partials/head') %>
</head>
<body class="bg-gray-100 font-sans">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">
    <h2 class="text-4xl font-bold text-center text-gray-900 mb-6">Checkout</h2>

    <div class="max-w-lg mx-auto bg-white p-8 rounded-lg shadow-lg">
        <h3 class="text-2xl font-bold text-gray-900 mb-6"><%= home.houseName %></h3>
        <p class="text-lg text-gray-600">Price: ₹ <%= home.pricePerNight %> / night</p>
        
        <!-- Date Picker or Other Details for Booking -->
        <form action="/bookings/confirm" method="POST">
            <label for="checkin">Check-in Date:</label>
            <input type="date" name="checkin" required />

            <label for="checkout">Checkout Date:</label>
            <input type="date" name="checkout" required />

            <button type="submit" class="w-full bg-red-500 text-white py-2 rounded-md hover:bg-red-600 transition duration-300 mt-4">Confirm Booking</button>
        </form>
    </div>
</main>

</body>
</html>
