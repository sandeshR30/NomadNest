<%- include('../partials/head') %>
</head>
<body class="bg-[#F8FAFC] font-sans">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">
    <h2 class="text-4xl font-bold text-center text-[#0F172A] mb-6">
        Your Favorite Homes
    </h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% favouritesHomes.forEach(home => { %>
            <li class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition duration-300">
                <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-48 object-cover"/>
                <div class="p-4 space-y-2">
                    <h2 class="text-xl font-semibold text-[#0F172A]"><%= home.houseName %></h2>
                    <p class="text-gray-600">📍 <%= home.location %></p>
                    <p class="text-lg font-bold text-[#0F172A]">₹ <%= home.price %> / night</p>
                </div>

                <div class="pt-2">
                    <form action="/favourites/delete/<%= home._id %>" method="POST" class="w-1/2 mx-auto">
                        <button type="submit"
                            class="w-full bg-[#DC2626] hover:bg-[#B91C1C] text-white font-semibold py-2 px-4 rounded-lg transition duration-300"
                            onclick="return confirm('Are you sure you want to delete this home?');">
                            Remove
                        </button>
                    </form>
                </div>
            </li>
        <% }); %>
    </ul>
</main>

</body>
</html>