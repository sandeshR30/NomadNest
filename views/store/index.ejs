<%- include('../partials/head') %>
</head>

<body class="bg-[#F8FAFC] font-sans text-gray-800">

<%- include('../partials/nav') %>

<main class="container mx-auto px-6 py-12">
    <h2 class="text-4xl font-bold text-center text-gray-900 mb-6">
        Welcome to <span class="text-[#0F172A]">NomadNest</span>
    </h2>
    
    <!-- Image section -->
    <div class="flex justify-center mb-12">
        <img src="/Image.png"
             alt="NomadNest"
             class="rounded-lg shadow-lg">
    </div>

    <!-- Description -->
    <p class="text-lg text-center text-gray-600 mb-10">
        Discover beautiful homes and experiences hosted by wonderful people all over the world.
        Here are your registered homes:
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% registeredHomes.forEach(home => { %>
            <li class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 border border-gray-200">
                
                <div class="cursor-pointer">
                    
                    <!-- House Image -->
                    <img
                        src="<%= home.photo %>"
                        alt="<%= home.houseName %>"
                        class="w-full h-48 object-cover"
                        onclick="window.location.href='/home-details/<%= home._id %>'"
                    />

                    <!-- Card Content -->
                    <div class="p-5 space-y-3">
                        
                        <!-- House Name -->
                        <h2 class="text-xl font-semibold text-[#0F172A]">
                            <%= home.houseName %>
                        </h2>

                        <!-- Location -->
                        <p class="text-gray-600">
                            📍 <%= home.location %>
                        </p>

                        <!-- Price & Rating -->
                        <div class="flex justify-between items-center pt-2">
                            <span class="text-lg font-bold text-[#0F172A]">
                                ₹ <%= home.price %> / night
                            </span>

                            <span class="flex items-center text-yellow-500 font-medium">
                                ⭐ <%= home.rating %>
                            </span>
                        </div>

                        <!-- Book Button -->
                        <div class="pt-4">
                            <a href="/book/<%= home._id %>"
                               class="block text-center bg-[#0F172A] hover:bg-[#1E293B] text-white font-semibold py-2.5 px-4 rounded-lg transition duration-300">
                               Book Now
                            </a>
                        </div>
                    </div>
                </div>
            </li>
        <% }); %>
    </ul>

</main>

<!-- Footer -->
<footer class="bg-[#0F172A] py-8 mt-12">
    <div class="container mx-auto text-center text-white">
        <p>&copy; 2025 NomadNest, Inc. All rights reserved.</p>
    </div>
</footer>

</body>
</html>